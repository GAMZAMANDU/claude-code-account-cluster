# ── dispatch ──────────────────────────────────────────────────────────────────

COMMANDS = {
    "ls":      cmd_ls,
    "use":     cmd_use,
    "best":    cmd_best,
    "log":     cmd_log,
    "stats":   cmd_stats,
    "capture": cmd_capture,
    "refresh": cmd_refresh,
    "remove":  cmd_remove,
    "help":    cmd_help,
}

def main():
    args = sys.argv[1:]
    if not args:
        cmd_ls([])
        return
    cmd  = args[0].lower()
    rest = args[1:]
    if cmd in COMMANDS:
        COMMANDS[cmd](rest)
    else:
        print(f"{RED}Unknown command: {cmd}{RESET}", file=sys.stderr)
        print(f"Run {CYAN}cc help{RESET} for usage.")
        sys.exit(1)

if __name__ == "__main__":
    main()
