#!/usr/bin/env python3
import json, os, sys
from datetime import datetime, date, timedelta, timezone
from collections import defaultdict

STATS = os.path.expanduser("~/.claude/stats-cache.json")

RESET  = "\033[0m"
BOLD   = "\033[1m"
DIM    = "\033[2m"
GREEN  = "\033[32m"
YELLOW = "\033[33m"
CYAN   = "\033[36m"
BLUE   = "\033[34m"
WHITE  = "\033[97m"
MAGENTA= "\033[35m"

def load():
    with open(STATS) as f:
        return json.load(f)

def total_tokens(model_usage):
    t = 0
    for m, v in model_usage.items():
        t += v.get("inputTokens", 0) + v.get("outputTokens", 0)
        t += v.get("cacheReadInputTokens", 0) + v.get("cacheCreationInputTokens", 0)
    return t

def fmt_tokens(n):
    if n >= 1_000_000_000:
        return f"{n/1_000_000_000:.1f}B"
    if n >= 1_000_000:
        return f"{n/1_000_000:.1f}M"
    if n >= 1_000:
        return f"{n/1_000:.1f}K"
    return str(n)

def fmt_dur(ms):
    s = ms // 1000
    h, s = divmod(s, 3600)
    m, s = divmod(s, 60)
    d, h = divmod(h, 24)
    parts = []
    if d: parts.append(f"{d}d")
    if h: parts.append(f"{h}h")
    if m: parts.append(f"{m}m")
    return " ".join(parts) or "0m"

def favorite_model(model_usage):
    best = max(model_usage.items(), key=lambda x: x[1].get("outputTokens", 0))
    name = best[0]
    name = name.replace("claude-", "").replace("-20251001","").replace("-20251101","").replace("-20250929","")
    parts = name.split("-")
    # Capitalize nicely: sonnet-4-6 → Sonnet 4.6
    result = []
    num_parts = []
    text_parts = []
    for p in parts:
        if p.replace(".","").isdigit():
            num_parts.append(p)
        else:
            text_parts.append(p.capitalize())
    base = " ".join(text_parts)
    if num_parts:
        base += " " + ".".join(num_parts)
    return base

def build_day_map(daily):
    dm = {}
    for entry in daily:
        dm[entry["date"]] = entry["messageCount"]
    return dm

def heatmap(day_map, weeks=53):
    today = date.today()
    # Start from Monday of (weeks) weeks ago
    start = today - timedelta(weeks=weeks - 1)
    start = start - timedelta(days=start.weekday())  # align to Monday

    # Collect all values for quantile thresholds
    vals = [v for v in day_map.values() if v > 0]
    if vals:
        vals.sort()
        p25 = vals[len(vals) // 4]
        p50 = vals[len(vals) // 2]
        p75 = vals[len(vals) * 3 // 4]
    else:
        p25, p50, p75 = 1, 5, 15

    CHARS = ["·", "░", "▒", "▓", "█"]
    COLORS = [DIM, "\033[38;5;22m", "\033[38;5;28m", "\033[38;5;34m", GREEN + BOLD]

    # Build grid: rows=7(Mon-Sun), cols=weeks
    grid = []
    month_labels = {}
    for col in range(weeks):
        week_chars = []
        for row in range(7):
            d = start + timedelta(weeks=col, days=row)
            ds = d.strftime("%Y-%m-%d")
            cnt = day_map.get(ds, 0)
            if d > today:
                ch, co = " ", ""
            elif cnt == 0:
                ch, co = CHARS[0], COLORS[0]
            elif cnt <= p25:
                ch, co = CHARS[1], COLORS[1]
            elif cnt <= p50:
                ch, co = CHARS[2], COLORS[2]
            elif cnt <= p75:
                ch, co = CHARS[3], COLORS[3]
            else:
                ch, co = CHARS[4], COLORS[4]
            week_chars.append((ch, co))
            # Month label on 1st of month
            if d.day == 1 and row == 0:
                month_labels[col] = d.strftime("%b")
        grid.append(week_chars)

    # Month header
    header = "     "
    prev_month_col = -4
    for col in range(weeks):
        label = month_labels.get(col)
        if label and col - prev_month_col >= 3:
            header += f"{CYAN}{label}{RESET}"
            prev_month_col = col
            col_skip = len(label)
        else:
            header += " "
    print(header)

    # Day rows
    DAY_LABELS = ["    ", "Mon ", "    ", "Wed ", "    ", "Fri ", "    "]
    for row in range(7):
        line = f"  {DIM}{DAY_LABELS[row]}{RESET}"
        for col in range(weeks):
            ch, co = grid[col][row]
            line += f"{co}{ch}{RESET}"
        print(line)

    # Legend
    print()
    legend = "  Less "
    for i, (ch, co) in enumerate(zip(CHARS[1:], COLORS[1:])):
        legend += f"{co}{ch}{RESET} "
    legend += "More"
    print(legend)

def streaks(day_map):
    if not day_map:
        return 0, 0, None, 0
    all_dates = sorted(day_map.keys())
    today = date.today()

    longest = 0
    current_start = None
    current_len = 0
    max_count = 0
    max_day = None
    streak = 0
    cur = 0

    prev = None
    for ds in all_dates:
        d = date.fromisoformat(ds)
        cnt = day_map[ds]
        if cnt > 0:
            if cnt > max_count:
                max_count = cnt
                max_day = ds
            if prev and (d - prev).days == 1:
                cur += 1
            else:
                cur = 1
            longest = max(longest, cur)
            prev = d
        else:
            prev = None
            cur = 0

    # Current streak — start from today; if today missing, allow 1-day gap (cache lag)
    d = today
    if day_map.get(d.strftime("%Y-%m-%d"), 0) == 0:
        d -= timedelta(days=1)
    streak = 0
    while True:
        ds = d.strftime("%Y-%m-%d")
        if day_map.get(ds, 0) > 0:
            streak += 1
            d -= timedelta(days=1)
        else:
            break

    active = sum(1 for v in day_map.values() if v > 0)
    return longest, streak, max_day, active

def fmt_date(ds):
    if not ds:
        return "?"
    try:
        d = date.fromisoformat(ds)
        return d.strftime("%b %-d")
    except:
        return ds

def main():
    d = load()

    day_map = build_day_map(d.get("dailyActivity", []))
    model_usage = d.get("modelUsage", {})
    longest_sess = d.get("longestSession", {})
    total_sess = d.get("totalSessions", 0)
    first_date = d.get("firstSessionDate", "")

    # Date range
    if first_date:
        first_dt = datetime.fromisoformat(first_date.replace("Z", "+00:00"))
        first_day = first_dt.date()
        total_days = (date.today() - first_day).days + 1
    else:
        total_days = 1

    tok = total_tokens(model_usage)
    fav = favorite_model(model_usage)
    longest_dur = fmt_dur(longest_sess.get("duration", 0))
    longest_streak, current_streak, max_day, active_days = streaks(day_map)

    print()
    print(f"  {BOLD}{WHITE}Overview{RESET}   {DIM}Models{RESET}")
    print()

    heatmap(day_map)

    print()
    print(f"  {DIM}{'─'*56}{RESET}")
    w = 28
    print(f"  {DIM}Favorite model:{RESET} {CYAN}{fav:<{w}}{RESET}{DIM}Total tokens:{RESET} {GREEN}{fmt_tokens(tok)}{RESET}")
    print()
    print(f"  {DIM}Sessions:{RESET} {WHITE}{total_sess:<{w-1}}{RESET}{DIM}Longest session:{RESET} {YELLOW}{longest_dur}{RESET}")
    print(f"  {DIM}Active days:{RESET} {WHITE}{active_days}/{total_days:<{w-len(str(active_days))-1}}{RESET}{DIM}Longest streak:{RESET} {YELLOW}{longest_streak} days{RESET}")
    print(f"  {DIM}Most active day:{RESET} {WHITE}{fmt_date(max_day):<{w}}{RESET}{DIM}Current streak:{RESET} {GREEN}{current_streak} days{RESET}")
    print(f"  {DIM}{'─'*56}{RESET}")
    print()

if __name__ == "__main__":
    main()
