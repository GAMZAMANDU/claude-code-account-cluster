#!/usr/bin/env bash
RESET="\033[0m"
BOLD="\033[1m"
DIM="\033[2m"
CYAN="\033[36m"
GREEN="\033[32m"
YELLOW="\033[33m"

echo
echo -e "  ${BOLD}cc-* Command Reference${RESET}"
echo -e "  ${DIM}────────────────────────────────────────────────${RESET}"
echo
echo -e "  ${CYAN}cc-ls${RESET}               계정 목록 + rate limit 시각화 (★ best 계정 표시)"
echo -e "  ${CYAN}cc-stats${RESET}            사용량 히트맵 + 통계"
echo -e "  ${CYAN}cc-best${RESET}             5H 최대 여유 계정으로 자동 전환"
echo -e "  ${CYAN}cc-use${RESET}              fzf 인터랙티브 계정 선택"
echo -e "  ${CYAN}cc-use${RESET} ${DIM}<index>${RESET}     지정 계정으로 전환 ${YELLOW}(Claude Code 종료 후 실행)${RESET}"
echo -e "  ${CYAN}cc-log${RESET} ${DIM}[n]${RESET}         전환 이력 조회 (기본 20개)"
echo -e "  ${CYAN}cc-capture${RESET}          현재 로그인 계정 저장 후 자동 로그아웃"
echo -e "  ${CYAN}cc-help${RESET}             이 도움말"
echo
echo -e "  ${BOLD}계정 추가${RESET}"
echo -e "  ${DIM}────────────────────────────────────────────────${RESET}"
echo -e "  1. ${GREEN}claude auth login${RESET}   → 추가할 계정으로 로그인"
echo -e "  2. ${GREEN}cc-capture${RESET}          → 캡처 + 자동 로그아웃"
echo -e "  3. 반복 후 ${GREEN}claude auth login${RESET} 으로 메인 계정 복구"
echo
echo -e "  ${BOLD}계정 전환${RESET}"
echo -e "  ${DIM}────────────────────────────────────────────────${RESET}"
echo -e "  1. Claude Code ${YELLOW}종료${RESET}"
echo -e "  2. ${GREEN}cc-best${RESET} 또는 ${GREEN}cc-use${RESET} (fzf picker)"
echo -e "  3. Claude Code 재실행"
echo
echo -e "  ${DIM}rate limit 막히면: cc-best 로 즉시 전환  ·  cc-log 로 이력 확인${RESET}"
echo
