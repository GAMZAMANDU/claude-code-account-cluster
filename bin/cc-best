#!/usr/bin/env python3
"""Switch to the account with most 5H remaining (tiebreak: 7D remaining).
If running inside Claude Code, auto-close, switch, and resume the session."""
import json, os, sys, subprocess, tempfile, stat

STORE = os.path.expanduser("~/.ClaudeCodeMultiAccounts.json")
CONFIG = os.path.expanduser("~/.claude.json")

def get_active_uuid():
    try:
        with open(CONFIG) as f:
            return json.load(f).get("oauthAccount", {}).get("accountUuid")
    except:
        return None

def inside_claude():
    return os.environ.get("CLAUDECODE") == "1"

def main():
    # Refresh snapshot
    try:
        creds_raw = subprocess.check_output(
            ["security", "find-generic-password", "-s", "Claude Code-credentials", "-w"],
            stderr=subprocess.DEVNULL
        ).decode().strip()
        with open(os.path.expanduser("~/.claude/.credentials.json"), "w") as f:
            f.write(creds_raw + "\n")
    except:
        pass
    subprocess.run(["cc-switch"], capture_output=True)

    with open(STORE) as f:
        store = json.load(f)

    accounts = store.get("accounts", [])
    active_uuid = get_active_uuid()

    best_idx = None
    best_score = (-1, -1)

    for i, acc in enumerate(accounts):
        usage = acc.get("usageSnapshot", {})
        fh = usage.get("five_hour", {})
        sd = usage.get("seven_day", {})
        fh_util = fh.get("utilization")
        sd_util = sd.get("utilization")
        fh_pct = (100 - fh_util) if fh_util is not None else 100
        sd_pct = (100 - sd_util) if sd_util is not None else 100
        score = (fh_pct, sd_pct)
        if score > best_score:
            best_score = score
            best_idx = i

    if best_idx is None:
        print("No accounts found.")
        sys.exit(1)

    acc = accounts[best_idx]
    meta = acc.get("metadata", {})
    email = meta.get("emailAddress", "?")
    name = meta.get("displayName", "?")
    uuid = meta.get("accountUuid")

    if uuid == active_uuid:
        print(f"Already on best account: [{best_idx}] {name} <{email}> (5H:{best_score[0]}% 7D:{best_score[1]}%)")
        sys.exit(0)

    print(f"Best: [{best_idx}] {name} <{email}> (5H:{best_score[0]}% 7D:{best_score[1]}%)")

    if inside_claude():
        session_id = os.environ.get("CLAUDE_CODE_SESSION_ID", "")
        claude_pid = os.environ.get("CMUX_CLAUDE_PID", "")
        claude_bin = os.environ.get("CMUX_AGENT_LAUNCH_EXECUTABLE",
                     os.path.expanduser("~/.local/bin/claude"))

        # Write nohup script that outlives this Claude Code session
        script = f"""#!/usr/bin/env bash
sleep 0.5
cc-use {best_idx}
sleep 0.3
if [ -n "{session_id}" ]; then
    {claude_bin} --resume {session_id}
else
    {claude_bin}
fi
"""
        fd, path = tempfile.mkstemp(suffix=".sh", prefix="cc-resume-")
        with os.fdopen(fd, "w") as f:
            f.write(script)
        os.chmod(path, stat.S_IRWXU)

        subprocess.Popen(
            ["nohup", "bash", path],
            stdout=open("/tmp/cc-resume.log", "w"),
            stderr=subprocess.STDOUT,
            stdin=subprocess.DEVNULL,
            start_new_session=True,
        )

        print(f"Switching → will resume session {session_id[:8]}... after restart.")
        # Kill current Claude Code process
        if claude_pid:
            os.kill(int(claude_pid), 15)  # SIGTERM
        sys.exit(0)
    else:
        # Not inside Claude Code — delegate to cc-use directly
        os.execv(os.path.expanduser("~/.local/bin/cc-use"), ["cc-use", str(best_idx)])

if __name__ == "__main__":
    main()
