{
  "name": "cc-multiaccounts",
  "description": "Claude Code multi-account switcher with rate limit visualization and auto-switching",
  "version": "1.0.0",
  "author": {
    "name": "gamzamandu",
    "url": "https://github.com/gamzamandu"
  },
  "license": "MIT",
  "homepage": "https://github.com/gamzamandu/cc-multiaccounts",
  "repository": "https://github.com/gamzamandu/cc-multiaccounts",
  "keywords": ["multi-account", "rate-limit", "switcher", "oauth"],
  "skills": ["./skills/cc/"],
  "hooks": {
    "Notification": [
      {
        "matcher": "rate_limit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/on-rate-limit.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
